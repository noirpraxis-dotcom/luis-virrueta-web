rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── USERS (existing) ───────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.email == 'luis.virrueta.contacto@gmail.com'
      );
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.email == 'luis.virrueta.contacto@gmail.com'
      );

      match /purchases/{purchaseId} {
        allow read: if request.auth != null && (
          request.auth.uid == userId ||
          request.auth.token.email == 'luis.virrueta.contacto@gmail.com' ||
          // Partner can read buyer's purchase
          ('partnerRef' in resource.data && resource.data.partnerRef != null && resource.data.partnerRef.uid == request.auth.uid) ||
          // Buyer can read partner's purchase
          ('linkedBuyerUid' in resource.data && resource.data.linkedBuyerUid == request.auth.uid)
        );
        allow create: if request.auth != null && (
          request.auth.uid == userId ||
          request.auth.token.email == 'luis.virrueta.contacto@gmail.com'
        );
        allow update: if request.auth != null && (
          request.auth.uid == userId ||
          request.auth.token.email == 'luis.virrueta.contacto@gmail.com' ||
          ('partnerEmail' in resource.data && resource.data.partnerEmail == request.auth.token.email) ||
          ('partnerRef' in resource.data && resource.data.partnerRef != null && resource.data.partnerRef.uid == request.auth.uid) ||
          ('linkedBuyerUid' in resource.data && resource.data.linkedBuyerUid == request.auth.uid)
        );
        allow delete: if request.auth != null && (
          request.auth.uid == userId ||
          request.auth.token.email == 'luis.virrueta.contacto@gmail.com'
        );
      }
    }

    // ─── BLOG ARTICLES ─────────────────────────────
    match /blog_articles/{articleId} {
      // Anyone can read published articles
      allow read: if true;
      // Only admin can write
      allow write: if request.auth != null
        && request.auth.token.email == 'luis.virrueta.contacto@gmail.com';
    }

    // ─── PARTNER INVITES (losdos flow) ─────────────
    match /partner_invites/{email} {
      // Any authenticated user can read (partner needs to find their invite)
      allow read: if request.auth != null;
      // Any authenticated user can create/update (buyer writes invite)
      allow write: if request.auth != null;
    }

    // ─── LABORATORIO ÉTICO: VOTOS ──────────────────
    match /laboratorio_votos/{votoId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // ─── LABORATORIO ÉTICO: COMENTARIOS ────────────
    match /laboratorio_comentarios/{commentId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }
  }
}
