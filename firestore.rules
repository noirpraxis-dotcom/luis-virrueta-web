rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── USERS (existing) ───────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /purchases/{purchaseId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ─── BLOG ARTICLES ─────────────────────────────
    match /blog_articles/{articleId} {
      // Anyone can read published articles
      allow read: if true;
      // Only admin can write
      allow write: if request.auth != null
        && request.auth.token.email == 'luis.virrueta.contacto@gmail.com';
    }

    // ─── LABORATORIO ÉTICO: VOTOS ──────────────────
    match /laboratorio_votos/{votoId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // ─── LABORATORIO ÉTICO: COMENTARIOS ────────────
    match /laboratorio_comentarios/{commentId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }
  }
}
