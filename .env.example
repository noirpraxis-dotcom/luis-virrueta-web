VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxx

# Backend API URL (Cloud Functions / serverless)
VITE_API_BASE_URL=https://tu-api.tudominio.com
